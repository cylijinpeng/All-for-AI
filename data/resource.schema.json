{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All for AI resource metadata",
  "type": "object",
  "required": ["name", "type", "category", "summary", "tags", "links"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "level": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
